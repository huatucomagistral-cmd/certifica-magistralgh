rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Fondos de plantillas: solo admins pueden subir/borrar, lectura pública para PDF generation
    match /templates/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // PDFs de certificados: solo admins pueden subir, lectura pública para descarga
    match /certificates/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
